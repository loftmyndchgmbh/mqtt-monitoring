# MQTT Broker Configuration
MQTT_BROKER=your-broker-url
MQTT_PORT=1883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
PUBLISHER_CLIENT_ID=asenta

# Ping Configuration
PING_HOST=193.5.176.14
PING_ATTEMPTS=3
PING_TIMEOUT=2

# Alert Configuration
ALERT_AFTER_MINUTES=60
ALERT_EMAIL_FROM=alert@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com

# Mailtrap SMTP Configuration
SMTP_SERVER=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password

# --- Gmail alternative ---
# Requires 2FA + App Password: https://myaccount.google.com/apppasswords
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: override path to config.ini (default: ./config.ini)
# MQTT_MONITOR_CONFIG=/etc/mqtt-monitoring/config.ini

# Optional: how long to subscribe before checking (default: 10 seconds)
# MQTT_WARMUP_SECONDS=10